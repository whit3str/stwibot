# ──────────────────────────────────────────────
# TWITCH
# ──────────────────────────────────────────────
# Token OAuth Twitch (obtenu sur https://twitchapps.com/tmi/)
# Format: oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_TOKEN=oauth:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Chaîne(s) Twitch à surveiller.
# Plusieurs chaînes possibles, séparées par des virgules :
TWITCH_CHANNELS=mistermv
# (rétro-compat : TWITCH_CHANNEL=mistermv est encore accepté pour une seule chaîne)

# Nom d'utilisateur de votre compte bot Twitch (ou votre compte perso)
TWITCH_BOT_NICK=mon_compte_twitch

# Utilisateurs dont les messages seront analysés (séparés par des virgules).
# Laissez vide pour surveiller TOUT le chat.
# Exemples : streamelements,streamlabs,nightbot,mistermv
TWITCH_ALLOWED_USERS=streamelements,streamlabs

# ──────────────────────────────────────────────
# STEAM
# ──────────────────────────────────────────────
STEAM_USERNAME=mon_login_steam
STEAM_PASSWORD=mon_mot_de_passe_steam

# shared_secret extrait de votre application Steam Guard Mobile
# (via Steam Desktop Authenticator ou extraction de l'app mobile)
# Exemple: kDhYr2...==  (chaîne base64)
STEAM_SHARED_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX==

# identity_secret (aussi dans le fichier .maFile)
STEAM_IDENTITY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX==

# SteamID 64 bits de votre compte (https://steamidfinder.com/)
STEAM_ID=76561198XXXXXXXXX

# ──────────────────────────────────────────────
# DIVERS
# ──────────────────────────────────────────────
# Niveau de log : INFO (défaut) ou DEBUG pour diagnostiquer.
# DEBUG affiche le reçu d'activation Steam brut, utile pour vérifier
# le nom de jeu détecté lors d'une activation.
LOG_LEVEL=INFO
